<?xml version="1.0" encoding="UTF-8"?>
<ProxyEndpoint name="default">
    <Description>Petstore Proxy Endpoint</Description>
    <PreFlow name="PreFlow">
        <Request>
            <Step>
                <Name>VerifyAPIKey</Name>
            </Step>
        </Request>
        <Response/>
    </PreFlow>
    <Flows>
        <Flow name="listPets">
            <Description>List all pets</Description>
            <Condition>(proxy.pathsuffix MatchesPath "/pets") and (request.verb = "GET")</Condition>
            <Request/>
            <Response/>
        </Flow>
        <Flow name="createPet">
            <Description>Create a new pet</Description>
            <Condition>(proxy.pathsuffix MatchesPath "/pets") and (request.verb = "POST")</Condition>
            <Request/>
            <Response/>
        </Flow>
        <Flow name="getPetById">
            <Description>Get a pet by ID</Description>
            <Condition>(proxy.pathsuffix MatchesPath "/pets/{petId}") and (request.verb = "GET")</Condition>
            <Request>
                <Step>
                    <Name>ExtractPathParams</Name>
                </Step>
            </Request>
            <Response/>
        </Flow>
        <Flow name="updatePet">
            <Description>Update a pet</Description>
            <Condition>(proxy.pathsuffix MatchesPath "/pets/{petId}") and (request.verb = "PUT")</Condition>
            <Request>
                <Step>
                    <Name>ExtractPathParams</Name>
                </Step>
            </Request>
            <Response/>
        </Flow>
        <Flow name="deletePet">
            <Description>Delete a pet</Description>
            <Condition>(proxy.pathsuffix MatchesPath "/pets/{petId}") and (request.verb = "DELETE")</Condition>
            <Request>
                <Step>
                    <Name>ExtractPathParams</Name>
                </Step>
            </Request>
            <Response/>
        </Flow>
    </Flows>
    <PostFlow name="PostFlow">
        <Request/>
        <Response/>
    </PostFlow>
    <HTTPProxyConnection>
        <BasePath>/v1</BasePath>
        <VirtualHost>default</VirtualHost>
        <VirtualHost>secure</VirtualHost>
    </HTTPProxyConnection>
    <RouteRule name="default">
        <TargetEndpoint>default</TargetEndpoint>
    </RouteRule>
</ProxyEndpoint>
